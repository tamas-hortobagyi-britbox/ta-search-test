    {
      "name": "TA_Test/Search",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Request Item Ddata via Rocket API GET /items/{id}",
              "// The selected TA environment `rocketItemQuery` variable points to the matching D3/Rocket environment.",
              "const getItemData = async (id, params = \"\") => {",
              "    const request = {",
              "        url: pm.environment.get(\"rocketItemQuery\").split(\"[ID]\").join(id) + params,",
              "        method: 'GET',",
              "        header: {",
              "            'Content-Type': 'application/json'",
              "        }",
              "    };",
              "    const result = await pm.sendRequest(request);",
              "",
              "    if (result.code == 200) return result.json();",
              "",
              "    return undefined;",
              "}",
              "",
              "// Transform the result to readible titles in order.",
              "if (pm.response.code == 200) {",
              "    const result = pm.response.json();",
              "    const recommendation = result.recommendationsResult?.recommendations?.recommendation;",
              "",
              "    if (recommendation) {",
              "        const request = pm.request?.body?.raw ? JSON.parse(pm.request.body.raw) : undefined;",
              "        if (recommendation.length > 0) {",
              "        let rocketQueryParams = \"\";",
              "        if (request) {",
              "            if (request.requestParameters?.region) {",
              "                rocketQueryParams += \"&segments=\" + request.requestParameters.region;",
              "            }",
              "            rocketQueryParams += \"&sub=\" + request.requestParameters?.product?.[0] || \"Premier\";",
              "        }",
              "",
              "            const resultTitles = [];",
              "            recommendation.forEach(async (item, i) => {",
              "                if (item?.contentItemId) {",
              "                    const itemId = request.requestParameters?.seriesFilter == \"episode\" ?",
              "                        item.contentItemId :",
              "                        item.seriesId || item.contentItemId;",
              "                    const data = item.contentItemName",
              "                        ? {title: item.contentItemName, type: (item.campaignType == \"SERIES\" ? \"show\" : \"movie\") } ",
              "                        : await getItemData(itemId, rocketQueryParams);",
              "                    ",
              "                    resultTitles[i] = data?.title ? (data.title + ` (${data.type}: ${itemId})${item.contentItemGroup ? \" - \" + item.contentItemGroup.contentItemGroupId : \"\"}`) : \"Error: \" + itemId;",
              "",
              "                    // Print only when all fields are filled - .find(), .indexOf() don't work.",
              "                    if (resultTitles.length == recommendation.length && resultTitles.findIndex((x) => x === undefined) == -1) {",
              "                        if (pm.request?.body?.raw && request.requestParameters?.term) {",
              "                            console.log(\"Term: \" + request.requestParameters.term);",
              "                        }",
              "                        ",
              "                        console.log(resultTitles); // titles in the same order as received",
              "                    }",
              "                }",
              "            });",
              "        } else {",
              "            console.log((request.requestParameters?.term ? \"Term: \" + request.requestParameters?.term : \"\") + \" -> ZERO RESULT\");",
              "        }",
              "    }",
              "}",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "protocolProfileBehavior": {
        "disabledSystemHeaders": {
          "accept": true,
          "connection": true
        }
      },
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Accept",
            "value": "application/json",
            "type": "text"
